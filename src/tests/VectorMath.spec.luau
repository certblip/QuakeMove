--!strict
local VectorMath = require(script.Parent.Parent.shared.MovementFramework.Math.VectorMath)

return function(t: any)
	t:describe("VectorMath.clipVelocity", function()
		t:it("removes the component into a plane (perfect slide)", function()
			local v = VectorMath.clipVelocity(Vector3.new(0, -10, 5), Vector3.yAxis, 1.0)
			t:expect(v.Y):toBeCloseTo(0, 1e-3)
			t:expect(v.Z):toBeCloseTo(5, 1e-3)
		end)
	end)
	t:describe("VectorMath.wishDirection", function()
		t:it("forward input with yaw 0 points toward -Z", function()
			local d = VectorMath.wishDirection(0, 0, 1)
			t:expect(d.Z):toBeLessThan(0)
			t:expect(math.abs(d.X)):toBeLessThan(1e-4)
		end)
		t:it("returns zero for no input", function()
			local d = VectorMath.wishDirection(1.2, 0, 0)
			t:expect(d.Magnitude):toBe(0)
		end)
		t:it("is unit length for diagonal input", function()
			local d = VectorMath.wishDirection(0.7, 1, 1)
			t:expect(d.Magnitude):toBeCloseTo(1, 1e-4)
		end)
	end)
	t:describe("VectorMath.surfaceAngle", function()
		t:it("flat ground is 0 degrees", function()
			t:expect(VectorMath.surfaceAngle(Vector3.yAxis)):toBeCloseTo(0, 1e-3)
		end)
		t:it("45 degree ramp", function()
			local n = Vector3.new(0, 1, 1).Unit
			t:expect(VectorMath.surfaceAngle(n)):toBeCloseTo(45, 0.5)
		end)
	end)
end
